# =====================================================
# CallSofia Bridge — Environment Variables
# =====================================================
# Copy this file to `.env.local` for local development,
# or set in Vercel for production deployments.

# ─── CallSofia Connection ──────────────────────────────
CALLSOFIA_API_BASE_URL=https://api.callsofia.co
CALLSOFIA_ORG_ID=10000000-0000-0000-0000-000000000001
CALLSOFIA_API_KEY=sk_prod_acmelaw_xxx
CALLSOFIA_WEBHOOK_SECRET=whsec_xxx

# ─── Storage ───────────────────────────────────────────
# Postgres only (Supabase, Neon, RDS, anywhere). Idempotency is enforced
# by the events table primary key — no Redis or KV required.
DATABASE_URL=postgres://...

# Vercel Queues (optional; falls back to in-process if unset)
VERCEL_QUEUE_PUBLISH_URL=
QUEUE_TOKEN=
QUEUE_INTERNAL_TOKEN=

# ─── Active CRM Adapter ────────────────────────────────
# Options: litify | generic-webhook | none
CRM_ADAPTER=litify

# ─── Litify (Salesforce) Auth ──────────────────────────
# Uses OAuth 2.0 Client Credentials Flow against {LOGIN_URL}/services/oauth2/token.
# Configure a Connected App with "Enable Client Credentials Flow" + a run-as user.
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
# DEPRECATED — only kept for back-compat with old configs. Bridge no longer
# uses these and emits a warning at runtime if any are set. Remove once OAuth
# rollout is complete (TODO: PR follow-up).
SALESFORCE_USERNAME=
SALESFORCE_PASSWORD=
SALESFORCE_SECURITY_TOKEN=

# ─── Litify Behavior ───────────────────────────────────
LITIFY_AUTO_CONVERT_QUALIFIED=false
INTAKE_DEFAULT_OWNER_ID=
INTAKE_COORDINATOR_USER_ID=
LITIFY_INTAKE_RECORD_TYPE_ID=
# Recording attachment mode:
#   url    — store presigned download URL on Intake.CallSofia_Recording_URL__c (default; cheap, URL expires)
#   attach — download OGG and upload as Salesforce ContentVersion (self-contained; OOM risk on Vercel for >25MB)
LITIFY_RECORDING_MODE=url

# ─── Event Handler Toggles ─────────────────────────────
HANDLE_CALL_RINGING=true
HANDLE_CALL_ANSWERED=false
HANDLE_CALL_IN_PROGRESS=false
HANDLE_CALL_ENDED=true
HANDLE_CALL_EXTRACTED=true
HANDLE_LEAD_QUALIFIED=true
HANDLE_LEAD_NEEDS_REVIEW=true
HANDLE_EVALUATION_COMPLETE=true
HANDLE_RECORDING_OGG=true

# ─── Generic Webhook Forwarder (alt adapter) ───────────
GENERIC_WEBHOOK_URL=
GENERIC_WEBHOOK_SECRET=
GENERIC_WEBHOOK_TRANSFORM=litify-shape

# ─── Reliability ───────────────────────────────────────
MAX_RETRIES=10
RETRY_BASE_DELAY_MS=1000
RETRY_MAX_DELAY_MS=300000
DEAD_LETTER_AFTER_DAYS=7

# ─── Admin ─────────────────────────────────────────────
ADMIN_PASSWORD=changeme_in_production
SLACK_ALERT_WEBHOOK_URL=

# ─── Observability ─────────────────────────────────────
MIRROR_TO_PLATFORM_API=true
LOG_LEVEL=info

NEXT_PUBLIC_BASE_URL=http://localhost:3000
